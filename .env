# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=cyberdefense-agents

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_INDEX_ALERTS=cyberdefense-alerts
ES_INDEX_THREATS=cyberdefense-threats

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── ML / Detection ───────────────────────────────────────────────────────────
MODEL_PATH=ml/models/threat_classifier.joblib
MODEL_CONFIDENCE_THRESHOLD=0.85
ANOMALY_SENSITIVITY=0.92
RETRAIN_INTERVAL_DAYS=7

# Detection thresholds (tunable without code changes)
THRESHOLD_SYN_FLOOD_PPS=200
THRESHOLD_PORT_SCAN_PORTS=15
THRESHOLD_BRUTE_FORCE=5
THRESHOLD_UEBA_ZSCORE=3.0
THRESHOLD_CVSS_HIGH=7.0
THRESHOLD_CVSS_CRITICAL=9.0

# ─── Response ─────────────────────────────────────────────────────────────────
AUTO_BLOCK_IP=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=forensics

# ─── ML Service ───────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001

# ─── Correlation ──────────────────────────────────────────────────────────────
CORRELATION_WINDOW_SEC=120
RESPONSE_ALERT_THRESHOLD=HIGH
